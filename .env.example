# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env` to version control.

# OpenAI-compatible LLM endpoint (used by data_generation/* and analysis/ambiguify_*.py)
LLM_API_BASE=https://your-llm-endpoint.example.com/v1
LLM_API_KEY=sk-your-api-key

# Default models (override per script with --model)
LLM_IMAGE_EDIT_MODEL=gemini-3-pro-image
LLM_TEXT_MODEL=gemini-2.5-flash

# HuggingFace (only needed for scripts/upload_to_hf.py)
HF_TOKEN=hf_your_token_here
HF_REPO_ID=your-org/vde-bench
HF_REPO_TYPE=dataset
